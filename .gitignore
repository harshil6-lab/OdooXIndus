# ------------------------------------------------------------
# CoreInventory .gitignore (fresh)
# ------------------------------------------------------------

# Dependencies
node_modules/

# Build artifacts
dist/
build/
out/
.vite/
.turbo/

# TypeScript incremental build output
*.tsbuildinfo

# Generated JS/typing artifacts from TS config sources
vite.config.js
vite.config.d.ts

# Environment files (keep sample env file tracked)
.env
.env.*
!.env.example

# Logs and runtime files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.seed
*.pid.lock

# Test and coverage output
coverage/
.nyc_output/

# Caches and temp
.cache/
.eslintcache
.parcel-cache/
.next/
.npm/
tmp/
temp/

# Optional REPL history
.node_repl_history

# IDE/editor files
.idea/
.vscode/
*.iml
*.ipr
*.iws
.history/
.settings/
.classpath
.project
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini
